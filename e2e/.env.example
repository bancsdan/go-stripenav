# E2E test harness environment.
# Copy to e2e/.env and fill in real values from your NAV technical user.
# In CI, inject the same keys via repository secrets — no .env file needed.
#
# Run the suite via: task test:e2e

# --- NAV (Online Számla v3.0) ---
# TestBaseURL is the safe default; set ProductionBaseURL only deliberately.
NAV_BASE_URL=https://api-test.onlineszamla.nav.gov.hu/invoiceService/v3
NAV_LOGIN=
NAV_PASSWORD=
# 11-digit composite: 8-digit taxpayerId + 1-digit vatCode + 2-digit countyCode.
# Example: 12345678-9-01
NAV_TAX_NUMBER=
# SHA3-512 signing material from the NAV portal.
NAV_SIGN_KEY=
# 16-byte AES-128-ECB exchange key from the NAV portal.
NAV_EXCHANGE_KEY=

# --- Supplier identity (the merchant the test invoices are issued from) ---
SUPPLIER_TAX_NUMBER=
SUPPLIER_NAME=
SUPPLIER_COUNTRY=HU
SUPPLIER_POSTAL_CODE=
SUPPLIER_CITY=
SUPPLIER_ADDRESS=

# --- Optional ---
# Bound the wait for a submission to reach accepted. Default 90s.
# E2E_ACCEPT_TIMEOUT=90s
