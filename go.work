go 1.26.2

// Local workspace ties the root module and the examples module into a
// single dev environment. Lets `go run ./examples/...`, `task dev`,
// and editor cross-module navigation work without per-command `cd`.
//
// This file is committed so every contributor's local clone behaves the
// same way. The companion go.work.sum is generated and gitignored.
use (
    .
    ./examples
)
